{
  "name": "clawdesktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env NODE_ENV=development vite --port 15173 --strictPort\" \"wait-on tcp:15173 && electron .\"",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac:intel": "vite build && electron-builder --mac --x64",
    "electron:build:mac:arm": "vite build && electron-builder --mac --arm64",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:all": "vite build && electron-builder -mwl",
    "build:desktop:all": "./build-desktop.sh"
  },
  "build": {
    "appId": "com.clawdesktop.app",
    "productName": "ClawDesktop",
    "artifactName": "${productName}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "!dist/*.dmg",
      "!dist/*.exe",
      "!dist/*.AppImage",
      "!dist/*.blockmap",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/logo.png",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": ["nsis"],
      "icon": "public/logo.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "public/logo.png",
      "category": "Network"
    }
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "axios": "^1.13.6",
    "lucide-react": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^5.4.21",
    "wait-on": "^9.0.4"
  }
}
